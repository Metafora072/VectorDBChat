+std::vector<Tag> load_tag_file(const std::string &path) {
+  std::vector<Tag> tags;
+  size_t n = 0, dim = 0;
+  pipeann::load_bin<Tag>(path, tags, n, dim);
+  if (dim != 1) throw std::runtime_error("tag file dimension must be 1: " + path);
+  return tags;
+}
