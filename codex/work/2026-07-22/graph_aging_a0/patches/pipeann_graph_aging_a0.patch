+struct ShadowReplayResult {
+  uint64_t candidates = 0;
+  uint64_t reactivated = 0;
+  double seconds = 0;
+};
+
+ShadowReplayResult oracle_shadow_replay(Index &index, const std::vector<uint64_t> &baseline_edges,
+                                        const pipeann::IndexBuildParameters &params, int threads) {
+  ShadowReplayResult result;
+  if (baseline_edges.empty()) return result;
+  auto start = std::chrono::steady_clock::now();
+
+  Tag max_tag = 0;
+  for (const auto &entry : index._tag_to_location) max_tag = std::max(max_tag, entry.first);
+  std::vector<uint32_t> tag_to_loc(static_cast<size_t>(max_tag) + 1, pipeann::kInvalidID);
+  for (const auto &entry : index._tag_to_location) tag_to_loc[entry.first] = entry.second;
+
+  std::vector<std::vector<uint32_t>> baseline_by_loc(index.max_points());
+  for (uint64_t edge : baseline_edges) {
+    const Tag owner_tag = static_cast<Tag>(edge >> 32);
+    const Tag nbr_tag = static_cast<Tag>(edge & 0xffffffffULL);
+    if (owner_tag >= tag_to_loc.size() || nbr_tag >= tag_to_loc.size()) continue;
+    const uint32_t owner = tag_to_loc[owner_tag];
+    const uint32_t nbr = tag_to_loc[nbr_tag];
+    if (owner == pipeann::kInvalidID || nbr == pipeann::kInvalidID || owner == nbr) continue;
+    baseline_by_loc[owner].push_back(nbr);
+  }
+
+  std::vector<uint64_t> candidates_per_node(index._nd, 0);
+  std::vector<uint64_t> reactivated_per_node(index._nd, 0);
+#pragma omp parallel for schedule(dynamic, 1024) num_threads(threads)
+  for (int64_t owner = 0; owner < static_cast<int64_t>(index._nd); ++owner) {
+    const auto &baseline_nbrs = baseline_by_loc[owner];
+    if (baseline_nbrs.empty()) continue;
+    const auto before = index._final_graph[owner];
+    std::vector<uint32_t> candidates = before;
+    candidates.insert(candidates.end(), baseline_nbrs.begin(), baseline_nbrs.end());
+    std::sort(candidates.begin(), candidates.end());
+    candidates.erase(std::unique(candidates.begin(), candidates.end()), candidates.end());
+    candidates.erase(std::remove(candidates.begin(), candidates.end(), static_cast<uint32_t>(owner)),
+                     candidates.end());
+
+    uint64_t missing = 0;
+    for (uint32_t nbr : baseline_nbrs) {
+      if (std::find(before.begin(), before.end(), nbr) == before.end()) ++missing;
+    }
+    if (missing == 0) continue;
+    candidates_per_node[owner] = missing;
+
+    std::vector<pipeann::Neighbor> pool;
+    pool.reserve(candidates.size());
+    for (uint32_t nbr : candidates) {
+      const float dist = index._distance->compare(index._data.data() + index._dim * owner,
+                                                  index._data.data() + index._dim * nbr, index._dim);
+      pool.emplace_back(nbr, dist);
+    }
+    std::vector<uint32_t> replayed;
+    pipeann::prune_neighbors(pool, replayed, params, index._dist_metric, [&index](uint32_t a, uint32_t b) {
+      return index._distance->compare(index._data.data() + index._dim * a,
+                                      index._data.data() + index._dim * b, index._dim);
+    });
+    uint64_t accepted = 0;
+    for (uint32_t nbr : baseline_nbrs) {
+      if (std::find(before.begin(), before.end(), nbr) == before.end() &&
+          std::find(replayed.begin(), replayed.end(), nbr) != replayed.end()) {
+        ++accepted;
+      }
+    }
+    reactivated_per_node[owner] = accepted;
+    index._final_graph[owner] = std::move(replayed);
+  }
+  result.candidates = std::accumulate(candidates_per_node.begin(), candidates_per_node.end(), uint64_t{0});
+  result.reactivated = std::accumulate(reactivated_per_node.begin(), reactivated_per_node.end(), uint64_t{0});
+  result.seconds = seconds_since(start);
+  return result;
+}
