+Metrics evaluate(Index &index, const std::string &query_file, const std::string &gt_file, size_t nqueries,
+                 unsigned search_L, const std::vector<uint64_t> &baseline_edges, std::vector<uint64_t> *current_out) {
+  std::vector<float> queries;
+  size_t query_n = 0, query_dim = 0;
+  pipeann::load_bin<float>(query_file, queries, query_n, query_dim);
+  if (query_dim != index._dim) throw std::runtime_error("query dimension mismatch");
+  nqueries = std::min(nqueries, query_n);
+
+  unsigned *gt_ids = nullptr;
+  float *gt_dists = nullptr;
+  unsigned *gt_tags = nullptr;
+  size_t gt_n = 0, gt_dim = 0;
+  pipeann::load_truthset(gt_file, gt_ids, gt_dists, gt_n, gt_dim, &gt_tags);
+  nqueries = std::min(nqueries, gt_n);
+  if (gt_dim < 10) throw std::runtime_error("ground truth has fewer than 10 neighbors");
+
+  std::vector<double> cmps(nqueries), hops(nqueries);
+  std::vector<uint64_t> hits(nqueries, 0);
+#pragma omp parallel for schedule(static)
+  for (int64_t qi = 0; qi < static_cast<int64_t>(nqueries); ++qi) {
+    std::vector<unsigned> ids(search_L);
+    std::vector<float> dists(search_L);
+    pipeann::QueryStats stats;
+    index.search(queries.data() + qi * query_dim, search_L, search_L, ids.data(), dists.data(), &stats);
+    std::unordered_set<unsigned> truth;
+    const unsigned *truth_values = gt_tags == nullptr ? gt_ids : gt_tags;
+    for (size_t k = 0; k < 10; ++k) truth.insert(truth_values[qi * gt_dim + k]);
+    size_t returned = 0;
+    for (unsigned loc : ids) {
+      auto it = index._location_to_tag.find(loc);
+      if (it == index._location_to_tag.end()) continue;
+      if (truth.count(it->second)) ++hits[qi];
+      if (++returned == 10) break;
+    }
+    cmps[qi] = stats.n_cmps;
+    hops[qi] = stats.n_hops;
+  }
+  delete[] gt_ids;
+  delete[] gt_dists;
+  delete[] gt_tags;
+
+  auto edges = graph_edges_by_tag(index);
+  Metrics m;
+  m.recall = static_cast<double>(std::accumulate(hits.begin(), hits.end(), uint64_t{0})) / (nqueries * 10.0);
+  std::vector<double> per_query_recall(nqueries);
+  for (size_t i = 0; i < nqueries; ++i) per_query_recall[i] = static_cast<double>(hits[i]) / 10.0;
+  m.recall_p01 = quantile(per_query_recall, 0.01);
+  m.recall_p10 = quantile(per_query_recall, 0.10);
+  m.recall_p50 = quantile(per_query_recall, 0.50);
+  m.recall_p90 = quantile(per_query_recall, 0.90);
+  m.cmps_mean = mean(cmps);
+  m.cmps_p50 = quantile(cmps, 0.50);
+  m.cmps_p95 = quantile(cmps, 0.95);
+  m.cmps_p99 = quantile(cmps, 0.99);
+  m.hops_mean = mean(hops);
+  m.hops_p50 = quantile(hops, 0.50);
+  m.hops_p95 = quantile(hops, 0.95);
+  m.hops_p99 = quantile(hops, 0.99);
+  m.edge_count = edges.size();
+  m.active_count = index._location_to_tag.size();
+  if (!baseline_edges.empty()) {
+    m.jaccard = edge_jaccard(edges, baseline_edges);
+    const auto diff = edge_diff(edges, baseline_edges);
+    m.edge_intersection = diff.intersection;
+    m.edge_missing_vs_g0 = diff.missing_vs_baseline;
+    m.edge_added_vs_g0 = diff.added_vs_baseline;
+    m.changed_owner_count = diff.changed_owners;
+    const uint64_t vector_bytes = index._dim * sizeof(float);
+    const uint64_t adjacency_bytes = index.range * sizeof(uint32_t);
+    m.logical_coupled_rewrite_bytes = diff.changed_owners * (vector_bytes + adjacency_bytes);
+    m.logical_topology_rewrite_bytes = diff.changed_owners * adjacency_bytes;
+    m.shadow_bytes_8 = diff.missing_vs_baseline * 8;
+    m.shadow_bytes_12 = diff.missing_vs_baseline * 12;
+  }
+  if (current_out != nullptr) *current_out = std::move(edges);
+  return m;
+}
