+namespace {
+using Tag = uint32_t;
+using Index = pipeann::Index<float, Tag>;
+
+struct Args {
+  std::unordered_map<std::string, std::string> kv;
+
+  Args(int argc, char **argv, int start) {
+    for (int i = start; i < argc; ++i) {
+      std::string key(argv[i]);
+      if (key.rfind("--", 0) != 0 || i + 1 >= argc) {
+        throw std::runtime_error("expected --key value, got: " + key);
+      }
+      kv[key.substr(2)] = argv[++i];
+    }
+  }
+
+  std::string get(const std::string &key, const std::string &fallback = "") const {
+    auto it = kv.find(key);
+    return it == kv.end() ? fallback : it->second;
+  }
+
+  uint64_t u64(const std::string &key, uint64_t fallback = 0) const {
+    auto value = get(key);
+    return value.empty() ? fallback : std::stoull(value);
+  }
+
+  double f64(const std::string &key, double fallback = 0) const {
+    auto value = get(key);
+    return value.empty() ? fallback : std::stod(value);
+  }
+};
+
+double seconds_since(const std::chrono::steady_clock::time_point &start) {
+  return std::chrono::duration<double>(std::chrono::steady_clock::now() - start).count();
+}
+
+double quantile(std::vector<double> values, double q) {
+  if (values.empty()) return 0;
+  std::sort(values.begin(), values.end());
+  const size_t i = std::min(values.size() - 1, static_cast<size_t>(std::floor(q * (values.size() - 1))));
+  return values[i];
+}
+
+double mean(const std::vector<double> &values) {
+  if (values.empty()) return 0;
+  return std::accumulate(values.begin(), values.end(), 0.0) / values.size();
+}
+
+std::vector<uint64_t> graph_edges_by_tag(const Index &index) {
+  std::vector<uint64_t> edges;
+  size_t reserve = 0;
+  for (const auto &nbrs : index._final_graph) reserve += nbrs.size();
+  edges.reserve(reserve);
+  for (uint32_t owner = 0; owner < index._final_graph.size(); ++owner) {
+    auto owner_it = index._location_to_tag.find(owner);
+    if (owner_it == index._location_to_tag.end()) continue;
+    for (uint32_t nbr : index._final_graph[owner]) {
+      auto nbr_it = index._location_to_tag.find(nbr);
+      if (nbr_it == index._location_to_tag.end()) continue;
+      edges.push_back((static_cast<uint64_t>(owner_it->second) << 32) | nbr_it->second);
+    }
+  }
+  std::sort(edges.begin(), edges.end());
+  edges.erase(std::unique(edges.begin(), edges.end()), edges.end());
+  return edges;
+}
+
+void save_edges(const std::string &path, const std::vector<uint64_t> &edges) {
+  if (path.empty() || path == "-") return;
+  std::ofstream out(path, std::ios::binary | std::ios::trunc);
+  uint64_t count = edges.size();
+  out.write(reinterpret_cast<const char *>(&count), sizeof(count));
+  out.write(reinterpret_cast<const char *>(edges.data()), edges.size() * sizeof(uint64_t));
+  if (!out) throw std::runtime_error("failed to save edge file: " + path);
+}
+
+std::vector<uint64_t> load_edges(const std::string &path) {
+  if (path.empty() || path == "-") return {};
+  std::ifstream in(path, std::ios::binary);
+  uint64_t count = 0;
+  in.read(reinterpret_cast<char *>(&count), sizeof(count));
+  std::vector<uint64_t> edges(count);
+  in.read(reinterpret_cast<char *>(edges.data()), edges.size() * sizeof(uint64_t));
+  if (!in) throw std::runtime_error("failed to load edge file: " + path);
+  return edges;
+}
+
+double edge_jaccard(const std::vector<uint64_t> &a, const std::vector<uint64_t> &b) {
+  if (a.empty() && b.empty()) return 1.0;
+  size_t i = 0, j = 0, intersection = 0;
+  while (i < a.size() && j < b.size()) {
+    if (a[i] == b[j]) {
+      ++intersection;
+      ++i;
+      ++j;
+    } else if (a[i] < b[j]) {
+      ++i;
+    } else {
+      ++j;
+    }
+  }
+  const size_t union_size = a.size() + b.size() - intersection;
+  return union_size == 0 ? 1.0 : static_cast<double>(intersection) / union_size;
+}
+
+struct EdgeDiff {
+  uint64_t intersection = 0;
+  uint64_t missing_vs_baseline = 0;
+  uint64_t added_vs_baseline = 0;
+  uint64_t changed_owners = 0;
+};
+
+EdgeDiff edge_diff(const std::vector<uint64_t> &current, const std::vector<uint64_t> &baseline) {
+  EdgeDiff result;
+  size_t i = 0, j = 0;
+  uint32_t last_changed_owner = std::numeric_limits<uint32_t>::max();
+  auto mark_changed = [&](uint64_t edge) {
+    const uint32_t owner = static_cast<uint32_t>(edge >> 32);
+    if (owner != last_changed_owner) {
+      ++result.changed_owners;
+      last_changed_owner = owner;
+    }
+  };
+  while (i < current.size() && j < baseline.size()) {
+    if (current[i] == baseline[j]) {
+      ++result.intersection;
+      ++i;
+      ++j;
+    } else if (current[i] < baseline[j]) {
+      mark_changed(current[i]);
+      ++result.added_vs_baseline;
+      ++i;
+    } else {
+      mark_changed(baseline[j]);
+      ++result.missing_vs_baseline;
+      ++j;
+    }
+  }
+  while (i < current.size()) {
+    mark_changed(current[i++]);
+    ++result.added_vs_baseline;
+  }
+  while (j < baseline.size()) {
+    mark_changed(baseline[j++]);
+    ++result.missing_vs_baseline;
+  }
+  return result;
+}
+
+struct Metrics {
+  double recall = 0;
+  double recall_p01 = 0, recall_p10 = 0, recall_p50 = 0, recall_p90 = 0;
+  double cmps_mean = 0, cmps_p50 = 0, cmps_p95 = 0, cmps_p99 = 0;
+  double hops_mean = 0, hops_p50 = 0, hops_p95 = 0, hops_p99 = 0;
+  double jaccard = -1;
+  uint64_t edge_count = 0;
+  uint64_t active_count = 0;
+  uint64_t edge_intersection = 0;
+  uint64_t edge_missing_vs_g0 = 0;
+  uint64_t edge_added_vs_g0 = 0;
+  uint64_t changed_owner_count = 0;
+  uint64_t logical_coupled_rewrite_bytes = 0;
+  uint64_t logical_topology_rewrite_bytes = 0;
+  uint64_t shadow_bytes_8 = 0;
+  uint64_t shadow_bytes_12 = 0;
+  uint64_t oracle_shadow_candidates = 0;
+  uint64_t oracle_shadow_reactivated = 0;
+  double oracle_shadow_acceptance = -1;
+  double oracle_shadow_seconds = 0;
+};
