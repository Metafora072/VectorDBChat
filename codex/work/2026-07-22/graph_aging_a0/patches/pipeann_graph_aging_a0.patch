+std::unique_ptr<Index> build_index(const Args &args, size_t npoints, double &build_seconds) {
+  size_t file_n = 0, dim = 0;
+  pipeann::get_bin_metadata(args.get("data"), file_n, dim);
+  if (npoints == 0) npoints = file_n;
+  std::vector<Tag> tags;
+  if (args.get("tags").empty() || args.get("tags") == "-") {
+    tags.resize(npoints);
+    std::iota(tags.begin(), tags.end(), Tag{0});
+  } else {
+    tags = load_tag_file(args.get("tags"));
+  }
+  if (tags.size() != npoints) throw std::runtime_error("tag count does not match npoints");
+  auto params = params_from(args);
+  auto index = std::make_unique<Index>(pipeann::Metric::L2, dim);
+  auto start = std::chrono::steady_clock::now();
+  index->build(args.get("data").c_str(), npoints, params, tags, false);
+  build_seconds = seconds_since(start);
+  return index;
+}
+
+void run_build(const Args &args) {
+  double build_seconds = 0;
+  auto index = build_index(args, args.u64("npoints"), build_seconds);
+  auto baseline = load_edges(args.get("baseline-edges", "-"));
+  std::vector<uint64_t> current;
+  auto metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                          args.u64("search-L", 96), baseline, &current);
+  save_edges(args.get("save-edges", "-"), current);
+  if (!args.get("save-index").empty() && args.get("save-index") != "-") {
+    pipeann::SSDIndex<float, Tag>::save_from_mem(*index, args.get("save-index"));
+  }
+  append_record(args.get("out"), json_record("static", args.get("label", "static"), args.u64("build-seed"), 0,
+                                             0, metrics, build_seconds, 0, args.u64("R", 64), args.u64("L", 96),
+                                             args.u64("search-L", 96), args.u64("nqueries", 1000), 0));
+}
+
+std::vector<uint64_t> parse_checkpoints(const std::string &text) {
+  std::vector<uint64_t> result;
+  std::stringstream in(text);
+  std::string token;
+  while (std::getline(in, token, ',')) result.push_back(std::stoull(token));
+  std::sort(result.begin(), result.end());
+  return result;
+}
+
+void run_a01(const Args &args) {
+  auto index = std::unique_ptr<Index>(pipeann::SSDIndex<float, Tag>::load_to_mem(args.get("index"), pipeann::Metric::L2));
+  std::vector<float> data;
+  size_t npoints = 0, dim = 0;
+  pipeann::load_bin<float>(args.get("data"), data, npoints, dim);
+  if (dim != index->_dim || npoints < index->_nd) throw std::runtime_error("A0-1 data/index mismatch");
+  npoints = index->_nd;
+  const size_t batch_size = std::min<size_t>(args.u64("batch"), npoints);
+  std::vector<uint32_t> candidates(npoints);
+  std::iota(candidates.begin(), candidates.end(), 0);
+  std::mt19937 rng(args.u64("update-seed"));
+  std::shuffle(candidates.begin(), candidates.end(), rng);
+  candidates.resize(batch_size);
+  const auto checkpoints = parse_checkpoints(args.get("checkpoints", "1,10,100"));
+  const auto baseline = load_edges(args.get("baseline-edges"));
+  auto params = params_from(args);
+  const int threads = args.u64("threads", 16);
+  double cumulative_update_seconds = 0;
+  size_t checkpoint_pos = 0;
+  for (uint64_t cycle = 1; cycle <= checkpoints.back(); ++cycle) {
+    std::shuffle(candidates.begin(), candidates.end(), rng);
+    auto start = std::chrono::steady_clock::now();
+#pragma omp parallel for schedule(dynamic, 16) num_threads(threads)
+    for (int64_t j = 0; j < static_cast<int64_t>(candidates.size()); ++j) {
+      const uint32_t original_tag = candidates[j];
+      const Tag duplicate_tag = static_cast<Tag>(npoints + original_tag);
+      index->insert_point(data.data() + static_cast<size_t>(original_tag) * dim, params, duplicate_tag);
+    }
+    for (uint32_t original_tag : candidates) {
+      const Tag duplicate_tag = static_cast<Tag>(npoints + original_tag);
+      if (index->lazy_delete(duplicate_tag) != 0) throw std::runtime_error("A0-1 lazy_delete failed");
+    }
+    index->consolidate(params);
+    cumulative_update_seconds += seconds_since(start);
+    if (cycle == checkpoints[checkpoint_pos]) {
+      auto metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                              args.u64("search-L", 96), baseline, nullptr);
+      append_record(args.get("out"),
+                    json_record("a0_1", args.get("label", "insert_delete"), args.u64("build-seed"),
+                                args.u64("update-seed"), cycle, metrics, 0, cumulative_update_seconds,
+                                args.u64("R", 64), args.u64("L", 96), args.u64("search-L", 96),
+                                args.u64("nqueries", 1000), batch_size));
+      const bool final_checkpoint = checkpoint_pos + 1 == checkpoints.size();
+      if (final_checkpoint && args.u64("oracle-shadow", 0) != 0) {
+        const auto replay = oracle_shadow_replay(*index, baseline, params, threads);
+        auto replay_metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                                       args.u64("search-L", 96), baseline, nullptr);
+        replay_metrics.oracle_shadow_candidates = replay.candidates;
+        replay_metrics.oracle_shadow_reactivated = replay.reactivated;
+        replay_metrics.oracle_shadow_acceptance = replay.candidates == 0
+                                                       ? 0
+                                                       : static_cast<double>(replay.reactivated) / replay.candidates;
+        replay_metrics.oracle_shadow_seconds = replay.seconds;
+        append_record(args.get("out"),
+                      json_record("a0_4", args.get("label", "insert_delete") + "_oracle_shadow",
+                                  args.u64("build-seed"), args.u64("update-seed"), cycle, replay_metrics, 0,
+                                  cumulative_update_seconds, args.u64("R", 64), args.u64("L", 96),
+                                  args.u64("search-L", 96), args.u64("nqueries", 1000), batch_size));
+      }
+      ++checkpoint_pos;
+      if (checkpoint_pos == checkpoints.size()) break;
+    }
+  }
+}
+
+void insert_range(Index &index, const std::vector<float> &data, const std::vector<Tag> &tags, size_t begin,
+                  size_t end, const pipeann::IndexBuildParameters &params, int threads) {
+#pragma omp parallel for schedule(dynamic, 16) num_threads(threads)
+  for (int64_t i = static_cast<int64_t>(begin); i < static_cast<int64_t>(end); ++i) {
+    index.insert_point(data.data() + static_cast<size_t>(i) * index._dim, params, tags[i]);
+  }
+}
+
+void run_path2(const Args &args) {
+  const size_t final_n = args.u64("final-n");
+  const size_t initial_n = args.u64("initial-n", final_n / 2);
+  double build_seconds = 0;
+  auto index = build_index(args, initial_n, build_seconds);
+  std::vector<float> data;
+  size_t file_n = 0, dim = 0;
+  pipeann::load_bin<float>(args.get("data"), data, file_n, dim);
+  auto full_tags = load_tag_file(args.get("full-tags"));
+  if (file_n < final_n || full_tags.size() < final_n) throw std::runtime_error("Path 2 input too small");
+  const size_t batch = args.u64("batch", (final_n - initial_n) / 5);
+  auto params = params_from(args);
+  auto start = std::chrono::steady_clock::now();
+  for (size_t begin = initial_n; begin < final_n; begin += batch) {
+    insert_range(*index, data, full_tags, begin, std::min(final_n, begin + batch), params, args.u64("threads", 16));
+  }
+  const double update_seconds = seconds_since(start);
+  auto baseline = load_edges(args.get("baseline-edges"));
+  auto preprune_metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                                   args.u64("search-L", 96), baseline, nullptr);
+  append_record(args.get("out"), json_record("a0_2_preprune", args.get("label", "path2_batched") + "_preprune",
+                                             args.u64("build-seed"), args.u64("update-seed"), 0,
+                                             preprune_metrics, build_seconds, update_seconds, args.u64("R", 64),
+                                             args.u64("L", 96), args.u64("search-L", 96),
+                                             args.u64("nqueries", 1000), batch));
+
+  auto prune_start = std::chrono::steady_clock::now();
+  index->final_prune(params);
+  const double final_prune_seconds = seconds_since(prune_start);
+  auto metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                          args.u64("search-L", 96), baseline, nullptr);
+  append_record(args.get("out"), json_record("a0_2", args.get("label", "path2_batched") + "_postprune",
+                                             args.u64("build-seed"), args.u64("update-seed"), 1, metrics,
+                                             build_seconds, update_seconds + final_prune_seconds,
+                                             args.u64("R", 64), args.u64("L", 96), args.u64("search-L", 96),
+                                             args.u64("nqueries", 1000), batch));
+  if (args.u64("oracle-shadow", 0) != 0) {
+    const auto replay = oracle_shadow_replay(*index, baseline, params, args.u64("threads", 16));
+    auto replay_metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                                   args.u64("search-L", 96), baseline, nullptr);
+    replay_metrics.oracle_shadow_candidates = replay.candidates;
+    replay_metrics.oracle_shadow_reactivated = replay.reactivated;
+    replay_metrics.oracle_shadow_acceptance = replay.candidates == 0
+                                                   ? 0
+                                                   : static_cast<double>(replay.reactivated) / replay.candidates;
+    replay_metrics.oracle_shadow_seconds = replay.seconds;
+    append_record(args.get("out"), json_record("a0_4", args.get("label", "path2_batched") + "_oracle_shadow",
+                                               args.u64("build-seed"), args.u64("update-seed"), 1,
+                                               replay_metrics, build_seconds,
+                                               update_seconds + final_prune_seconds + replay.seconds,
+                                               args.u64("R", 64), args.u64("L", 96), args.u64("search-L", 96),
+                                               args.u64("nqueries", 1000), batch));
+  }
+}
+
+void run_path3(const Args &args) {
+  const size_t final_n = args.u64("final-n");
+  const size_t total_n = args.u64("npoints");
+  const size_t initial_n = args.u64("initial-n", total_n);
+  double build_seconds = 0;
+  auto index = build_index(args, initial_n, build_seconds);
+  auto params = params_from(args);
+  auto start = std::chrono::steady_clock::now();
+  if (initial_n < total_n) {
+    std::vector<float> data;
+    size_t file_n = 0, dim = 0;
+    pipeann::load_bin<float>(args.get("data"), data, file_n, dim);
+    auto full_tags = load_tag_file(args.get("full-tags"));
+    if (file_n < total_n || full_tags.size() < total_n) throw std::runtime_error("Path 3 input too small");
+    insert_range(*index, data, full_tags, initial_n, total_n, params, args.u64("threads", 16));
+  }
+  for (Tag tag = static_cast<Tag>(final_n); tag < total_n; ++tag) {
+    if (index->lazy_delete(tag) != 0) throw std::runtime_error("Path 3 lazy_delete failed");
+  }
+  index->consolidate(params);
+  const double update_seconds = seconds_since(start);
+  auto baseline = load_edges(args.get("baseline-edges"));
+  auto preprune_metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                                   args.u64("search-L", 96), baseline, nullptr);
+  append_record(args.get("out"), json_record("a0_2_preprune", args.get("label", "path3_overfill_delete") + "_preprune",
+                                             args.u64("build-seed"), args.u64("update-seed"), 0,
+                                             preprune_metrics, build_seconds, update_seconds,
+                                             args.u64("R", 64), args.u64("L", 96),
+                                             args.u64("search-L", 96), args.u64("nqueries", 1000),
+                                             total_n - initial_n));
+
+  auto prune_start = std::chrono::steady_clock::now();
+  index->final_prune(params);
+  const double final_prune_seconds = seconds_since(prune_start);
+  auto metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                          args.u64("search-L", 96), baseline, nullptr);
+  append_record(args.get("out"), json_record("a0_2", args.get("label", "path3_overfill_delete") + "_postprune",
+                                             args.u64("build-seed"), args.u64("update-seed"), 1, metrics,
+                                             build_seconds, update_seconds + final_prune_seconds,
+                                             args.u64("R", 64), args.u64("L", 96),
+                                             args.u64("search-L", 96), args.u64("nqueries", 1000), total_n - initial_n));
+  if (args.u64("oracle-shadow", 0) != 0) {
+    const auto replay = oracle_shadow_replay(*index, baseline, params, args.u64("threads", 16));
+    auto replay_metrics = evaluate(*index, args.get("query"), args.get("gt"), args.u64("nqueries", 1000),
+                                   args.u64("search-L", 96), baseline, nullptr);
+    replay_metrics.oracle_shadow_candidates = replay.candidates;
+    replay_metrics.oracle_shadow_reactivated = replay.reactivated;
+    replay_metrics.oracle_shadow_acceptance = replay.candidates == 0
+                                                   ? 0
+                                                   : static_cast<double>(replay.reactivated) / replay.candidates;
+    replay_metrics.oracle_shadow_seconds = replay.seconds;
+    append_record(args.get("out"), json_record("a0_4", args.get("label", "path3_overfill_delete") + "_oracle_shadow",
+                                               args.u64("build-seed"), args.u64("update-seed"), 1,
+                                               replay_metrics, build_seconds,
+                                               update_seconds + final_prune_seconds + replay.seconds,
+                                               args.u64("R", 64), args.u64("L", 96),
+                                               args.u64("search-L", 96), args.u64("nqueries", 1000),
+                                               total_n - initial_n));
+  }
+}
+}  // namespace
+
+int main(int argc, char **argv) {
+  try {
+    if (argc < 2) throw std::runtime_error("usage: graph_aging_a0 <build|a01|path2|path3> --key value ...");
+    const std::string mode(argv[1]);
+    Args args(argc, argv, 2);
+    if (mode == "build") run_build(args);
+    else if (mode == "a01") run_a01(args);
+    else if (mode == "path2") run_path2(args);
+    else if (mode == "path3") run_path3(args);
+    else throw std::runtime_error("unknown mode: " + mode);
+    return 0;
+  } catch (const std::exception &e) {
+    std::cerr << "graph_aging_a0 error: " << e.what() << std::endl;
+    return 2;
+  }
+}

