+  std::cout << ",\"first_result_cohort\":";
+  print_array(acc.first_result);
+  std::cout << ",\"transition_counts\":[";
+  for (size_t i = 0; i < kCohorts; ++i) {
+    if (i) std::cout << ",";
+    print_array(acc.transitions[i]);
+  }
+  std::cout << "]}";
+}
+}  // namespace
+
+int main(int argc, char **argv) {
+  try {
+    Args args(argc, argv);
+    auto index = std::unique_ptr<Index>(
+        pipeann::SSDIndex<float, Tag>::load_to_mem(args.get("index"), pipeann::Metric::L2));
+    const size_t cohort_size = args.u64("cohort-size", index->_nd / kCohorts);
+    if (cohort_size * kCohorts != index->_nd) throw std::runtime_error("index does not contain four equal cohorts");
+
+    std::vector<float> queries;
+    size_t query_n = 0, query_dim = 0;
+    pipeann::load_bin<float>(args.get("query"), queries, query_n, query_dim);
+    if (query_dim != index->_dim) throw std::runtime_error("query dimension mismatch");
+    unsigned *gt_ids = nullptr;
+    float *gt_dists = nullptr;
+    unsigned *gt_tags = nullptr;
+    size_t gt_n = 0, gt_dim = 0;
+    pipeann::load_truthset(args.get("gt"), gt_ids, gt_dists, gt_n, gt_dim, &gt_tags);
+    if (gt_dim < 10) throw std::runtime_error("ground truth has fewer than 10 neighbors");
+    const size_t nqueries = std::min({args.u64("nqueries", query_n), query_n, gt_n});
+    const unsigned search_L = args.u64("search-L", 96);
+    const int threads = args.u64("threads", 12);
+    std::vector<std::array<Accumulator, kCohorts>> locals(threads);
+
+#pragma omp parallel for schedule(static) num_threads(threads)
+    for (int64_t qi = 0; qi < static_cast<int64_t>(nqueries); ++qi) {
+      const int tid = omp_get_thread_num();
+      const unsigned *truth_values = gt_tags == nullptr ? gt_ids : gt_tags;
+      const size_t query_cohort = cohort(truth_values[qi * gt_dim], cohort_size);
+      auto &acc = locals[tid][query_cohort];
+      ++acc.queries;
+
+      std::vector<unsigned> ids(search_L);
+      std::vector<float> distances(search_L);
+      std::vector<uint32_t> trace;
+      pipeann::QueryStats stats;
+      index->search(queries.data() + qi * query_dim, search_L, search_L, ids.data(), distances.data(),
+                    &stats, nullptr, &trace);
+      acc.comparisons += stats.n_cmps;
+      acc.visited += stats.n_hops;
+
+      std::unordered_set<unsigned> truth;
+      for (size_t k = 0; k < 10; ++k) truth.insert(truth_values[qi * gt_dim + k]);
+      size_t returned = 0;
+      for (unsigned location : ids) {
+        auto tag_it = index->_location_to_tag.find(location);
+        if (tag_it == index->_location_to_tag.end()) continue;
+        if (truth.count(tag_it->second)) ++acc.recall_hits;
+        if (returned == 0) ++acc.first_result[cohort(tag_it->second, cohort_size)];
+        if (++returned == 10) break;
+      }
+
+      bool entered = false;
+      size_t previous = kCohorts;
+      for (size_t expansion = 0; expansion < trace.size(); ++expansion) {
+        auto tag_it = index->_location_to_tag.find(trace[expansion]);
+        if (tag_it == index->_location_to_tag.end()) continue;
+        const size_t current = cohort(tag_it->second, cohort_size);
+        if (expansion == 0) ++acc.first_expanded[current];
+        if (previous < kCohorts) ++acc.transitions[previous][current];
+        previous = current;
+        if (!entered && current == query_cohort) {
+          entered = true;
+          ++acc.target_entry_reached;
+          acc.target_entry_expansion += expansion + 1;
+        }
+      }
+    }
+
+    delete[] gt_ids;
+    delete[] gt_dists;
+    delete[] gt_tags;
+    std::array<Accumulator, kCohorts> cohorts{};
+    for (const auto &local : locals) {
+      for (size_t c = 0; c < kCohorts; ++c) cohorts[c].merge(local[c]);
+    }
+    Accumulator overall;
+    for (const auto &acc : cohorts) overall.merge(acc);
+
+    std::cout << std::setprecision(10) << "{\"label\":\"" << args.get("label")
+              << "\",\"seed\":" << args.u64("seed") << ",\"nqueries\":" << nqueries
+              << ",\"search_L\":" << search_L << ",\"cohorts\":[";
+    for (size_t c = 0; c < kCohorts; ++c) {
+      if (c) std::cout << ",";
+      print_accumulator(cohorts[c]);
+    }
+    std::cout << "],\"overall\":";
+    print_accumulator(overall);
+    std::cout << "}\n";
+    return 0;
+  } catch (const std::exception &error) {
+    std::cerr << "p03_query_a0 error: " << error.what() << "\n";
+    return 2;
+  }
+}
