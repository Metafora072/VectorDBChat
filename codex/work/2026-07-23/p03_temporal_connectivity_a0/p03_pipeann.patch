+  }
+};
+
+struct Accumulator {
+  uint64_t queries = 0;
+  uint64_t recall_hits = 0;
+  double comparisons = 0;
+  double visited = 0;
+  uint64_t target_entry_reached = 0;
+  double target_entry_expansion = 0;
+  std::array<uint64_t, kCohorts> first_expanded{};
+  std::array<uint64_t, kCohorts> first_result{};
+  std::array<std::array<uint64_t, kCohorts>, kCohorts> transitions{};
+
+  void merge(const Accumulator &other) {
+    queries += other.queries;
+    recall_hits += other.recall_hits;
+    comparisons += other.comparisons;
+    visited += other.visited;
+    target_entry_reached += other.target_entry_reached;
+    target_entry_expansion += other.target_entry_expansion;
+    for (size_t i = 0; i < kCohorts; ++i) {
+      first_expanded[i] += other.first_expanded[i];
+      first_result[i] += other.first_result[i];
+      for (size_t j = 0; j < kCohorts; ++j) transitions[i][j] += other.transitions[i][j];
+    }
+  }
+};
+
+size_t cohort(Tag tag, size_t cohort_size) {
+  return std::min(kCohorts - 1, static_cast<size_t>(tag) / cohort_size);
+}
+
+template <typename T>
+void print_array(const std::array<T, kCohorts> &values) {
+  std::cout << "[";
+  for (size_t i = 0; i < kCohorts; ++i) {
+    if (i) std::cout << ",";
+    std::cout << values[i];
+  }
+  std::cout << "]";
+}
+
+void print_accumulator(const Accumulator &acc) {
+  std::cout << "{\"queries\":" << acc.queries
