--- /dev/null
+++ b/tests/p03_graph_analyzer.cpp
@@ -0,0 +1,280 @@
+#include <algorithm>
+#include <array>
+#include <cstdint>
+#include <fstream>
+#include <iomanip>
+#include <iostream>
+#include <numeric>
+#include <queue>
+#include <random>
+#include <stdexcept>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+namespace {
+constexpr size_t kCohorts = 4;
+
+struct Args {
+  std::unordered_map<std::string, std::string> values;
+  Args(int argc, char **argv) {
+    for (int i = 1; i < argc; ++i) {
+      std::string key(argv[i]);
+      if (key.rfind("--", 0) != 0 || i + 1 >= argc) throw std::runtime_error("expected --key value");
+      values[key.substr(2)] = argv[++i];
+    }
+  }
+  std::string get(const std::string &key, const std::string &fallback = "") const {
+    auto it = values.find(key);
+    return it == values.end() ? fallback : it->second;
+  }
+  uint64_t u64(const std::string &key, uint64_t fallback = 0) const {
+    auto value = get(key);
+    return value.empty() ? fallback : std::stoull(value);
+  }
+};
+
+struct CSR {
+  std::vector<uint64_t> offsets;
+  std::vector<uint32_t> neighbors;
+};
+
+size_t cohort(uint32_t tag, size_t cohort_size) {
+  return std::min(kCohorts - 1, static_cast<size_t>(tag) / cohort_size);
+}
+
+std::vector<uint64_t> read_edges(const std::string &path) {
+  std::ifstream in(path, std::ios::binary);
+  uint64_t count = 0;
+  in.read(reinterpret_cast<char *>(&count), sizeof(count));
+  std::vector<uint64_t> edges(count);
+  in.read(reinterpret_cast<char *>(edges.data()), static_cast<std::streamsize>(count * sizeof(uint64_t)));
+  if (!in) throw std::runtime_error("failed to read edge file: " + path);
+  return edges;
+}
+
+std::pair<CSR, CSR> build_csrs(const std::vector<uint64_t> &edges, size_t npoints) {
+  CSR out, rev;
+  out.offsets.assign(npoints + 1, 0);
+  rev.offsets.assign(npoints + 1, 0);
+  for (uint64_t packed : edges) {
+    uint32_t src = static_cast<uint32_t>(packed >> 32);
+    uint32_t dst = static_cast<uint32_t>(packed);
+    if (src >= npoints || dst >= npoints) throw std::runtime_error("edge tag exceeds npoints");
+    ++out.offsets[src + 1];
+    ++rev.offsets[dst + 1];
+  }
+  std::partial_sum(out.offsets.begin(), out.offsets.end(), out.offsets.begin());
+  std::partial_sum(rev.offsets.begin(), rev.offsets.end(), rev.offsets.begin());
+  out.neighbors.resize(edges.size());
+  rev.neighbors.resize(edges.size());
+  auto out_pos = out.offsets;
+  auto rev_pos = rev.offsets;
+  for (uint64_t packed : edges) {
+    uint32_t src = static_cast<uint32_t>(packed >> 32);
+    uint32_t dst = static_cast<uint32_t>(packed);
+    out.neighbors[out_pos[src]++] = dst;
+    rev.neighbors[rev_pos[dst]++] = src;
+  }
+  return {std::move(out), std::move(rev)};
+}
+
+std::pair<uint64_t, uint64_t> strongly_connected_components(const CSR &out, const CSR &rev) {
+  const size_t n = out.offsets.size() - 1;
+  std::vector<uint8_t> seen(n, 0);
+  std::vector<uint32_t> order;
+  order.reserve(n);
+  struct Frame { uint32_t node; uint64_t next; };
+  std::vector<Frame> stack;
+  for (uint32_t root = 0; root < n; ++root) {
+    if (seen[root]) continue;
+    seen[root] = 1;
+    stack.push_back({root, out.offsets[root]});
+    while (!stack.empty()) {
+      auto &frame = stack.back();
+      const uint64_t end = out.offsets[frame.node + 1];
+      if (frame.next < end) {
+        uint32_t next = out.neighbors[frame.next++];
+        if (!seen[next]) {
+          seen[next] = 1;
+          stack.push_back({next, out.offsets[next]});
+        }
+      } else {
+        order.push_back(frame.node);
+        stack.pop_back();
+      }
+    }
+  }
+
+  std::fill(seen.begin(), seen.end(), 0);
+  std::vector<uint32_t> todo;
+  uint64_t components = 0, largest = 0;
+  for (auto it = order.rbegin(); it != order.rend(); ++it) {
+    const uint32_t root = *it;
+    if (seen[root]) continue;
+    ++components;
+    uint64_t size = 0;
+    seen[root] = 1;
+    todo.push_back(root);
+    while (!todo.empty()) {
+      const uint32_t node = todo.back();
+      todo.pop_back();
+      ++size;
+      for (uint64_t p = rev.offsets[node]; p < rev.offsets[node + 1]; ++p) {
+        const uint32_t next = rev.neighbors[p];
+        if (!seen[next]) {
+          seen[next] = 1;
+          todo.push_back(next);
+        }
+      }
+    }
+    largest = std::max(largest, size);
+  }
+  return {components, largest};
+}
+
+struct ReachSummary {
+  double rate = 0;
+  double mean = 0;
+  int p50 = -1;
+  int p95 = -1;
+};
+
+std::array<std::array<ReachSummary, kCohorts>, kCohorts> reachability(
+    const CSR &rev, size_t cohort_size, size_t targets_per_cohort, uint64_t seed) {
+  const size_t n = rev.offsets.size() - 1;
+  std::array<std::array<ReachSummary, kCohorts>, kCohorts> result{};
+  std::mt19937_64 rng(seed);
+  for (size_t target_cohort = 0; target_cohort < kCohorts; ++target_cohort) {
+    std::vector<uint32_t> candidates(cohort_size);
+    std::iota(candidates.begin(), candidates.end(), static_cast<uint32_t>(target_cohort * cohort_size));
+    std::shuffle(candidates.begin(), candidates.end(), rng);
+    candidates.resize(std::min(targets_per_cohort, candidates.size()));
+
+    std::vector<int32_t> distance(n, -1);
+    std::queue<uint32_t> queue;
+    for (uint32_t target : candidates) {
+      distance[target] = 0;
+      queue.push(target);
+    }
+    while (!queue.empty()) {
+      const uint32_t node = queue.front();
+      queue.pop();
+      for (uint64_t p = rev.offsets[node]; p < rev.offsets[node + 1]; ++p) {
+        const uint32_t predecessor = rev.neighbors[p];
+        if (distance[predecessor] < 0) {
+          distance[predecessor] = distance[node] + 1;
+          queue.push(predecessor);
+        }
+      }
+    }
+
+    for (size_t source_cohort = 0; source_cohort < kCohorts; ++source_cohort) {
+      std::vector<int32_t> reached;
+      const size_t begin = source_cohort * cohort_size;
+      const size_t end = std::min(n, begin + cohort_size);
+      reached.reserve(end - begin);
+      for (size_t node = begin; node < end; ++node) {
+        if (distance[node] >= 0) reached.push_back(distance[node]);
+      }
+      auto &summary = result[source_cohort][target_cohort];
+      summary.rate = static_cast<double>(reached.size()) / (end - begin);
+      if (!reached.empty()) {
+        const uint64_t sum = std::accumulate(reached.begin(), reached.end(), uint64_t{0});
+        summary.mean = static_cast<double>(sum) / reached.size();
+        std::sort(reached.begin(), reached.end());
+        summary.p50 = reached[(reached.size() - 1) / 2];
+        summary.p95 = reached[static_cast<size_t>(0.95 * (reached.size() - 1))];
+      }
+    }
+  }
+  return result;
+}
+
+template <typename T>
+void print_vector(const std::array<T, kCohorts> &values) {
+  std::cout << "[";
+  for (size_t i = 0; i < kCohorts; ++i) {
+    if (i) std::cout << ",";
+    std::cout << values[i];
+  }
+  std::cout << "]";
+}
+}  // namespace
+
+int main(int argc, char **argv) {
+  try {
+    Args args(argc, argv);
+    const size_t npoints = args.u64("npoints");
+    const size_t cohort_size = args.u64("cohort-size", npoints / kCohorts);
+    const size_t R = args.u64("R", 64);
+    if (npoints == 0 || cohort_size == 0 || cohort_size * kCohorts != npoints) {
+      throw std::runtime_error("npoints must equal four equal cohorts");
+    }
+    const auto edges = read_edges(args.get("edges"));
+    std::array<std::array<uint64_t, kCohorts>, kCohorts> counts{};
+    std::array<uint64_t, kCohorts> outgoing{}, incoming{};
+    for (uint64_t packed : edges) {
+      const uint32_t src = static_cast<uint32_t>(packed >> 32);
+      const uint32_t dst = static_cast<uint32_t>(packed);
+      const size_t sc = cohort(src, cohort_size), dc = cohort(dst, cohort_size);
+      ++counts[sc][dc];
+      ++outgoing[sc];
+      ++incoming[dc];
+    }
+    auto [out, rev] = build_csrs(edges, npoints);
+    const auto [scc_count, largest_scc] = strongly_connected_components(out, rev);
+    const auto reach = reachability(rev, cohort_size, args.u64("reach-targets", 1024), args.u64("seed", 0));
+
+    std::cout << std::setprecision(10) << "{";
+    std::cout << "\"label\":\"" << args.get("label") << "\",\"seed\":" << args.u64("seed")
+              << ",\"npoints\":" << npoints << ",\"R\":" << R << ",\"edge_count\":" << edges.size();
+    std::cout << ",\"matrix_counts\":[";
+    for (size_t i = 0; i < kCohorts; ++i) {
+      if (i) std::cout << ",";
+      print_vector(counts[i]);
+    }
+    std::cout << "],\"matrix_density_r\":[";
+    for (size_t i = 0; i < kCohorts; ++i) {
+      if (i) std::cout << ",";
+      std::array<double, kCohorts> row{};
+      for (size_t j = 0; j < kCohorts; ++j) row[j] = static_cast<double>(counts[i][j]) / (cohort_size * R);
+      print_vector(row);
+    }
+    std::cout << "],\"matrix_source_mass\":[";
+    for (size_t i = 0; i < kCohorts; ++i) {
+      if (i) std::cout << ",";
+      std::array<double, kCohorts> row{};
+      for (size_t j = 0; j < kCohorts; ++j) row[j] = static_cast<double>(counts[i][j]) / outgoing[i];
+      print_vector(row);
+    }
+    std::array<double, kCohorts> out_cross{}, in_cross{}, same_cross_ratio{};
+    for (size_t i = 0; i < kCohorts; ++i) {
+      out_cross[i] = 1.0 - static_cast<double>(counts[i][i]) / outgoing[i];
+      in_cross[i] = 1.0 - static_cast<double>(counts[i][i]) / incoming[i];
+      same_cross_ratio[i] = static_cast<double>(counts[i][i]) / std::max<uint64_t>(1, outgoing[i] - counts[i][i]);
+    }
+    std::cout << "],\"outgoing_cross_mass\":"; print_vector(out_cross);
+    std::cout << ",\"incoming_cross_mass\":"; print_vector(in_cross);
+    std::cout << ",\"same_cross_ratio\":"; print_vector(same_cross_ratio);
+    std::cout << ",\"scc_count\":" << scc_count << ",\"largest_scc\":" << largest_scc
+              << ",\"largest_scc_fraction\":" << static_cast<double>(largest_scc) / npoints;
+    std::cout << ",\"reachability\":[";
+    for (size_t i = 0; i < kCohorts; ++i) {
+      if (i) std::cout << ",";
+      std::cout << "[";
+      for (size_t j = 0; j < kCohorts; ++j) {
+        if (j) std::cout << ",";
+        const auto &r = reach[i][j];
+        std::cout << "{\"rate\":" << r.rate << ",\"mean_hops\":" << r.mean
+                  << ",\"p50_hops\":" << r.p50 << ",\"p95_hops\":" << r.p95 << "}";
+      }
+      std::cout << "]";
+    }
+    std::cout << "]}\n";
+    return 0;
+  } catch (const std::exception &error) {
+    std::cerr << "p03_graph_analyzer error: " << error.what() << "\n";
+    return 2;
+  }
+}
