+template<typename T, typename TagT = uint32_t>
+uint64_t get_atlas_trace(const std::string &data_bin, const std::string &trace_bin,
+                         std::vector<TagT> &delete_tags, std::vector<TagT> &insert_tags,
+                         std::vector<T> &data_load) {
+  std::ifstream trace(trace_bin, std::ios::binary);
+  int32_t n = 0;
+  trace.read(reinterpret_cast<char *>(&n), sizeof(n));
+  if (!trace || n <= 0) throw std::runtime_error("invalid ATLAS_TRACE_BIN: " + trace_bin);
+  delete_tags.resize(n);
+  insert_tags.resize(n);
+  trace.read(reinterpret_cast<char *>(delete_tags.data()), n * sizeof(TagT));
+  trace.read(reinterpret_cast<char *>(insert_tags.data()), n * sizeof(TagT));
+  if (!trace) throw std::runtime_error("truncated ATLAS_TRACE_BIN: " + trace_bin);
+
+  std::ifstream data(data_bin, std::ios::binary);
+  int32_t npts = 0, dim = 0;
+  data.read(reinterpret_cast<char *>(&npts), sizeof(npts));
+  data.read(reinterpret_cast<char *>(&dim), sizeof(dim));
+  data_load.resize(static_cast<size_t>(n) * dim * 2);
+  for (int32_t i = 0; i < n; ++i) {
+    if (insert_tags[i] >= static_cast<TagT>(npts))
+      throw std::runtime_error("Atlas insert tag exceeds dataset rows");
+    data.seekg(2 * sizeof(int32_t) + static_cast<uint64_t>(insert_tags[i]) * dim * sizeof(T));
+    data.read(reinterpret_cast<char *>(data_load.data() + static_cast<size_t>(i) * dim), dim * sizeof(T));
+  }
+  if (!data) throw std::runtime_error("failed loading Atlas insert vectors");
+  return static_cast<uint64_t>(n);
+}
